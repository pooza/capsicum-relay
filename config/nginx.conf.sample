# /etc/nginx/sites-available/capsicum-relay
# relay.capsicum.shrieker.net

upstream capsicum_relay {
    server 127.0.0.1:9292;
}

server {
    listen 443 ssl http2;
    server_name relay.capsicum.shrieker.net;

    ssl_certificate     /etc/letsencrypt/live/relay.capsicum.shrieker.net/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/relay.capsicum.shrieker.net/privkey.pem;

    access_log /var/log/nginx/capsicum-relay-access.log;
    error_log  /var/log/nginx/capsicum-relay-error.log;

    location / {
        proxy_pass http://capsicum_relay;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}

server {
    listen 80;
    server_name relay.capsicum.shrieker.net;
    return 301 https://$host$request_uri;
}
